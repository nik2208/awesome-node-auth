# ============================================================
# awesome-node-auth-advanced-demo — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
#
# Generated for: awesome-node-auth
# Framework: express
# Auth mode: cookies
# ============================================================

# ---- Application ------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---- JWT Secrets (REQUIRED) -------------------------------------------------
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=CHANGE_ME_ACCESS_$(framework.toUpperCase())_$(appName.toUpperCase().replace(/-/g, '_'))
REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_$(framework.toUpperCase())_$(appName.toUpperCase().replace(/-/g, '_'))

# ---- Token Lifetimes --------------------------------------------------------
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- Cookie / CSRF (cookie auth mode) --------------------------------------
# Set to "true" in production (HTTPS only)
NODE_ENV=production
# CSRF protection — set to "true" when sameSite=none (cross-origin cookies)
# CSRF_ENABLED=true

# ---- Email / Mailer ---------------------------------------------------------
# Full URL of your HTTP mailer endpoint (receives POST requests)
MAILER_ENDPOINT=https://mailer.example.com/send
# API key for the mailer endpoint
MAILER_API_KEY=your-mailer-api-key
# Sender address
MAILER_FROM=noreply@node-auth-advanced-demo.com
# Site URL used to build reset / verification links
SITE_URL=https://awesome-node-auth-advanced-demo.com

# ---- OAuth — Google ---------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://awesome-node-auth-advanced-demo.com/auth/oauth/google/callback

# ---- OAuth — GitHub ---------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://awesome-node-auth-advanced-demo.com/auth/oauth/github/callback

# ---- MongoDB ----------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/awesome-node-auth-advanced-demo

# ============================================================
# Security reminders:
#  1. Use at least 64 hex characters for JWT secrets
#  2. Set NODE_ENV=production in production deployments
#  3. Use HTTPS in production (required for secure cookies)
#  4. The admin UI is protected by the first-user access policy by default
# ============================================================
