# ── awesome-node-auth NestJS demo — environment variables ─────────────────────────────
# Copy this file to .env and fill in real values to enable all features.
# The demo works out-of-the-box with the built-in fallback values below.

# JWT signing secrets (REQUIRED in production — use long random strings)
ACCESS_TOKEN_SECRET=demo-access-secret-change-in-production
REFRESH_TOKEN_SECRET=demo-refresh-secret-change-in-production

# Server
PORT=3000
NODE_ENV=development

# Admin panel password

