{
  "name": "node-auth-nestjs-fullstack",
  "version": "1.0.0",
  "description": "NestJS fullstack demo for awesome-node-auth — in-memory store, JWT cookies, guards, admin panel.",
  "scripts": {
    "start": "ts-node -r reflect-metadata src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only -r reflect-metadata src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "awesome-node-auth": "^1.8.3",
    "cookie-parser": "^1.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}