{
  "name": "awesome-node-auth-angular-ssr",
  "version": "1.0.0",
  "description": "Angular 19 SSR demo for awesome-node-auth — guards, interceptors, CSRF, session restore.",
  "scripts": {
    "start": "concurrently \"node api-server.js\" \"ng serve --proxy-config proxy.conf.json --open\"",
    "start:api": "node api-server.js",
    "build": "ng build",
    "build:ssr": "ng build",
    "serve:ssr": "node dist/awesome-node-auth-angular-ssr/server/server.mjs",
    "ng": "ng"
  },
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/platform-server": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@angular/ssr": "^19.2.21",
    "awesome-node-auth": "^1.5.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.21",
    "@angular/cli": "^19.2.21",
    "@angular/compiler-cli": "^19.2.21",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
